PORT=3001
# For cloud deploy (Render/Railway/etc), prefer DATABASE_URL:
# DATABASE_URL=postgresql://user:password@host:5432/database

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password
DB_NAME=customers

# If omitted, app enables SSL automatically when NODE_ENV=production
# or DATABASE_URL is provided.
DB_SSL=false
